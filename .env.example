# Storage Backend Configuration
# Supported backends: json, sqlite, postgres, postgresql, mysql, database
# Default: json (local file storage)
STORAGE_BACKEND=json

# File Paths Configuration (defaults shown below, uncomment to override)
# CONFIG_DIR=./data
# CONFIG_FILE=./data/config.json
# TOKENS_FILE=./data/tokens.json
# DB_FILE=./data/flowith.db

# JSON Storage Files (for STORAGE_BACKEND=json)
# ACCOUNTS_FILE=./data/accounts.json
# AUTH_KEYS_FILE=./data/auth_keys.json

# Database URL (for sqlite/postgres/mysql backends)
# DATABASE_URL=sqlite:///./data/accounts.db
